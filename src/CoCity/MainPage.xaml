<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:CoCity.ViewModels"
             x:Class="CoCity.MainPage"
             x:DataType="viewModels:MainPageViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">
            <Label Text="{Binding PageTitle}"
                   Style="{StaticResource Headline}"
                   SemanticProperties.HeadingLevel="Level1" />

            <Label Text="{Binding PageSubtitle}"
                   Style="{StaticResource SubHeadline}"
                   SemanticProperties.HeadingLevel="Level2" />

            <Label Text="{Binding RealmSummary}" />

            <Border Padding="16"
                    Stroke="#D0D7DE"
                    BackgroundColor="#F8FAFC">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Treasury"
                           FontAttributes="Bold"
                           FontSize="20" />
                    <Label Text="{Binding Treasury.FundsSummary}" />
                    <Label Text="{Binding Treasury.TaxIncomeSummary}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Regions"
                   FontAttributes="Bold"
                   FontSize="20" />

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Regions}"
                                 Spacing="12">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:RegionCardViewModel">
                        <Border Padding="14"
                                Stroke="#D0D7DE">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding SpiritualVeinSummary}" />
                                <Label Text="{Binding BaselineSummary}" />
                                <Label Text="{Binding LocalPowerSummary}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Label Text="Mortal Towns"
                   FontAttributes="Bold"
                   FontSize="20" />

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Towns}"
                                 Spacing="12">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:TownCardViewModel">
                        <Border Padding="14"
                                Stroke="#D0D7DE">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding LocationSummary}" />
                                <Label Text="{Binding PopulationSummary}" />
                                <Label Text="{Binding IndustrySummary}" />
                                <Label Text="{Binding OutputSummary}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Label Text="Sects"
                   FontAttributes="Bold"
                   FontSize="20" />

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Sects}"
                                 Spacing="12">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:SectCardViewModel">
                        <Border Padding="14"
                                Stroke="#D0D7DE">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding LocationSummary}" />
                                <Label Text="{Binding FinanceSummary}" />
                                <Label Text="{Binding OutputSummary}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Label Text="Ministries"
                   FontAttributes="Bold"
                   FontSize="20" />

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Ministries}"
                                 Spacing="12">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:MinistryCardViewModel">
                        <Border Padding="14"
                                Stroke="#D0D7DE">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding AuthoritySummary}" />
                                <Label Text="{Binding ResponsibilitySummary}" />
                                <Label Text="{Binding StandardSummary}" />
                                <Label Text="{Binding MinisterSummary}" />
                                <Label Text="{Binding TeamSummary}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
