# .gitignore for Visual Studio / .NET / C# projects
# Exclude build outputs, user-specific files, IDE/workspace settings, OS files, logs,
# and common dependency directories.

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Bb]in/
[Oo]bj/
**/bin/
**/obj/
out/
artifacts/

# MSBuild generated files
*.cache
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb

# Rider (JetBrains)
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# NuGet packages
*.nupkg
**/packages/
project.lock.json
project.fragment.lock.json
project.assets.json
.nuget/

# User-specific and temporary files
*.log
*.vsix
*.userprefs
*.suo
*.user

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Publish output
publish/
*.publishsettings
*.pubxml.user
*.azurePubxml
*.Publish.xml

# IIS Express
.vs/*/applicationhost.config

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
Thumbs.db
desktop.ini
.DS_Store
ehthumbs.db

# Temporary and backup files
*.tmp
*.temp
*.bak
*.swp
*.orig
*.old

# Generated files
*.g.cs
*.g.i.cs

# Database files (local dev)
*.db

# Add project-specific ignores below as needed
